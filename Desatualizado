/* ════ TOAST ════ */
let _tt;
function toast(msg,type='ok'){
  const el=document.getElementById('toast');
  document.getElementById('t-msg').textContent=msg;
  document.getElementById('t-ic').textContent=type==='ok'?'✓':'✕';
  el.className=`toast t${type}`;
  void el.offsetWidth;el.classList.add('show');
  clearTimeout(_tt);_tt=setTimeout(()=>el.classList.remove('show'),3000);
}
document.addEventListener('keydown',e=>{if(e.key==='Enter'&&document.getElementById('sec-login')?.classList.contains('active'))doLogin()});
