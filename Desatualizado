function pgEscalas(){
  const days=['DOM','SEG','TER','QUA','QUI','SEX','SÁB'];
  const now=new Date();const mes=now.toLocaleDateString('pt-BR',{month:'long',year:'numeric'});
  const diasMes=new Date(now.getFullYear(),now.getMonth()+1,0).getDate();
  const primeiroDia=new Date(now.getFullYear(),now.getMonth(),1).getDay();
  return `
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.9rem;flex-wrap:wrap;gap:.75rem">
    <div style="font-family:var(--cond);font-size:18px;font-weight:700;color:var(--navy);text-transform:capitalize">${mes}</div>
    <button class="btn btn-primary btn-sm" onclick="toast('Configure as escalas em Configurações','ok')">⚙️ Configurar turnos</button>
  </div>
  <div class="card">
    <div class="ch"><div class="ct">Calendário — ${mes}</div></div>
    <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:5px;text-align:center">
      ${days.map(d=>`<div style="font-size:9px;font-weight:700;color:var(--gray-400);padding:5px">${d}</div>`).join('')}
      ${Array(primeiroDia).fill('<div></div>').join('')}
      ${Array.from({length:diasMes},(_,i)=>{
        const d=i+1,isToday=d===now.getDate();
        const isWk=((primeiroDia+i)%7===0||((primeiroDia+i)%7===6));
        const bg=isToday?'var(--navy)':isWk?'var(--gray-100)':'var(--navy-pale)';
        const cl=isToday?'#fff':isWk?'var(--gray-400)':'var(--navy)';
        return `<div style="padding:8px 4px;border-radius:7px;font-size:12px;font-weight:${isToday?800:600};background:${bg};color:${cl};cursor:pointer" onclick="toast('Dia ${d} selecionado','ok')">${d}</div>`;
      }).join('')}
    </div>
    <div style="display:flex;gap:14px;margin-top:.9rem;flex-wrap:wrap">
      ${[['var(--navy-pale)','Dia útil'],['var(--gray-100)','Fim de semana'],['var(--navy)','Hoje']].map(([bg,l])=>`<span style="font-size:12px;display:flex;align-items:center;gap:6px"><span style="width:10px;height:10px;border-radius:3px;background:${bg};display:inline-block"></span>${l}</span>`).join('')}
    </div>
  </div>`;
}

