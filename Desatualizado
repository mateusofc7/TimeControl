      </div>
    </div>
    <div class="al-foot">© 2026 Time Control · Todos os direitos reservados.</div>
  </div>

  <div class="auth-right">
    <div class="auth-box">
      <div class="auth-tabs">
        <button class="at-btn active" id="at-login" onclick="authTab('login')">Entrar</button>
        <button class="at-btn" id="at-reg" onclick="authTab('reg')">Criar conta</button>
      </div>

      <!-- LOGIN -->
      <div class="f-sec active" id="sec-login">
        <div id="login-main">
          <div class="auth-title">Bem-vindo de volta</div>
          <div class="auth-sub">Selecione seu perfil e acesse o sistema</div>
          <div style="margin-bottom:.9rem">
            <div class="f-label" style="margin-bottom:6px"><span>Perfil de acesso</span></div>
            <div class="prof-grid">
              <div><input type="radio" name="li-role" id="lr-admin" value="admin" class="prof-radio" checked><label for="lr-admin" class="prof-lbl"><span class="pic">🛡️</span>Administrador</label></div>
              <div><input type="radio" name="li-role" id="lr-rh"   value="rh"    class="prof-radio"><label for="lr-rh"   class="prof-lbl"><span class="pic">👥</span>RH</label></div>
              <div><input type="radio" name="li-role" id="lr-gest" value="gestor" class="prof-radio"><label for="lr-gest" class="prof-lbl"><span class="pic">📋</span>Gestor</label></div>
              <div><input type="radio" name="li-role" id="lr-func" value="func"  class="prof-radio"><label for="lr-func" class="prof-lbl"><span class="pic">🧑‍💼</span>Funcionário</label></div>
            </div>
          </div>
          <div class="f-group">
            <div class="f-label"><span>E-mail</span></div>
            <div class="f-wrap"><span class="f-ic">✉</span><input class="f-in" type="email" id="li-email" placeholder="seu@email.com" value="admin@timecontrol.com.br"></div>
            <div class="f-msg" id="li-em"></div>
          </div>
          <div class="f-group">
            <div class="f-label"><span>Senha</span><button class="btn-ghost" onclick="showForgot()">Esqueci a senha</button></div>
            <div class="f-wrap"><span class="f-ic">🔒</span><input class="f-in" type="password" id="li-pass" placeholder="••••••••" value="12345678"><button class="f-eye" onclick="eyeT('li-pass',this)">👁</button></div>
            <div class="f-msg" id="li-pm"></div>
          </div>
          <div class="chk-row" style="margin-bottom:1rem"><input type="checkbox" id="remember" checked><label for="remember">Manter conectado neste dispositivo</label></div>
          <button class="btn-auth" id="btn-login" onclick="doLogin()">ENTRAR NO SISTEMA</button>
          <div class="divider">ou</div>
          <div style="text-align:center;font-size:13px;color:var(--gray-400)">Não tem conta? <button class="btn-ghost" onclick="authTab('reg')">Criar conta</button></div>
        </div>
        <div class="forgot-panel" id="forgot-p">
          <div class="auth-title">Recuperar senha</div>
          <div class="auth-sub">Enviaremos um link para o seu e-mail</div>
          <div class="f-group"><div class="f-label"><span>E-mail</span></div><div class="f-wrap"><span class="f-ic">✉</span><input class="f-in" type="email" id="forg-e" placeholder="seu@email.com"></div></div>
          <button class="btn-auth" style="margin-bottom:10px" onclick="doForgot()">ENVIAR LINK</button>
          <button class="btn-back" style="width:100%" onclick="hideForgot()">← VOLTAR AO LOGIN</button>
        </div>
      </div>

      <!-- REGISTRO -->
      <div class="f-sec" id="sec-reg">
        <div class="success-sc" id="reg-ok">
          <div class="suc-icon">✓</div>
          <div class="suc-title">Conta criada!</div>
          <div class="suc-sub">Cadastro realizado com sucesso.<br>Verifique seu e-mail para ativar.</div>
          <button class="btn-auth" onclick="authTab('login')">IR PARA O LOGIN</button>
        </div>
        <div id="reg-form">
          <div class="auth-title">Criar conta</div>
          <div class="auth-sub">Preencha os dados para começar</div>
          <div class="steps" id="steps">
            <div class="step-it active" id="si1"><div class="step-circ">1</div><div class="step-lbl">Perfil</div></div>
            <div class="step-it" id="si2"><div class="step-circ">2</div><div class="step-lbl">Dados</div></div>
            <div class="step-it" id="si3"><div class="step-circ">3</div><div class="step-lbl">Acesso</div></div>
          </div>
          <div class="step-panel active" id="sp1">
            <div class="f-group">
              <div class="f-label"><span>Perfil</span></div>
              <div class="prof-grid">
                <div><input type="radio" name="rg-role" id="rr-a" value="admin" class="prof-radio"><label for="rr-a" class="prof-lbl"><span class="pic">🛡️</span>Administrador</label></div>
                <div><input type="radio" name="rg-role" id="rr-r" value="rh"    class="prof-radio"><label for="rr-r" class="prof-lbl"><span class="pic">👥</span>RH</label></div>
                <div><input type="radio" name="rg-role" id="rr-g" value="gestor" class="prof-radio"><label for="rr-g" class="prof-lbl"><span class="pic">📋</span>Gestor</label></div>
                <div><input type="radio" name="rg-role" id="rr-f" value="func"  class="prof-radio"><label for="rr-f" class="prof-lbl"><span class="pic">🧑‍💼</span>Funcionário</label></div>
              </div>
              <div class="f-msg err" id="rr-m"></div>
            </div>
            <div class="f-group" id="eg" style="display:none"><div class="f-label"><span>Nome da empresa</span></div><div class="f-wrap"><span class="f-ic">🏢</span><input class="f-in" id="rg-emp" placeholder="Ex: Empresa ABC Ltda."></div><div class="f-msg" id="em-m"></div></div>
            <div class="f-group" id="cg" style="display:none"><div class="f-label"><span>Código da empresa</span></div><div class="f-wrap"><span class="f-ic">#</span><input class="f-in" id="rg-cod" placeholder="TC-XXXX-XXXX" style="text-transform:uppercase;letter-spacing:.08em" oninput="validarCodigoAoDigitar(this)"></div><div class="f-msg" id="co-m"></div></div>
            <button class="btn-auth" onclick="goStep(2)">PRÓXIMO →</button>
          </div>
          <div class="step-panel" id="sp2">
            <div class="f-row2" style="margin-bottom:.9rem">
              <div><div class="f-label"><span>Nome</span></div><div class="f-wrap"><span class="f-ic">👤</span><input class="f-in" id="rg-nome" placeholder="Nome"></div><div class="f-msg" id="no-m"></div></div>
              <div><div class="f-label"><span>Sobrenome</span></div><div class="f-wrap"><span class="f-ic">👤</span><input class="f-in" id="rg-sobr" placeholder="Sobrenome"></div></div>
            </div>
            <div class="f-group"><div class="f-label"><span>CPF</span></div><div class="f-wrap"><span class="f-ic">🪪</span><input class="f-in" id="rg-cpf" placeholder="000.000.000-00" maxlength="14" oninput="mCPF(this)"></div><div class="f-msg" id="cp-m"></div></div>
            <div class="f-group"><div class="f-label"><span>Telefone</span></div><div class="f-wrap"><span class="f-ic">📱</span><input class="f-in" id="rg-tel" placeholder="(00) 00000-0000" maxlength="15" oninput="mPhone(this)"></div></div>
            <div class="f-group"><div class="f-label"><span>Cargo</span></div><div class="f-wrap"><span class="f-ic">💼</span><input class="f-in" id="rg-cargo" placeholder="Ex: Analista de RH"></div></div>
            <div class="btn-nav-row"><button class="btn-back" onclick="goStep(1)">← VOLTAR</button><button class="btn-auth btn-next" onclick="goStep(3)">PRÓXIMO →</button></div>
          </div>
          <div class="step-panel" id="sp3">
            <div class="f-group"><div class="f-label"><span>E-mail</span></div><div class="f-wrap"><span class="f-ic">✉</span><input class="f-in" type="email" id="rg-email" placeholder="seu@email.com" oninput="chkE(this)"></div><div class="f-msg" id="re-m"></div></div>
            <div class="f-group"><div class="f-label"><span>Senha</span></div><div class="f-wrap"><span class="f-ic">🔒</span><input class="f-in" type="password" id="rg-pass" placeholder="Mínimo 8 caracteres" oninput="chkS(this)"><button class="f-eye" onclick="eyeT('rg-pass',this)">👁</button></div>
              <div class="str-wrap" id="str-w"><div class="str-bar"><div class="str-fill" id="str-f"></div></div><div class="str-lbl" id="str-l"></div></div>
              <div class="f-msg" id="rp-m"></div>
            </div>
