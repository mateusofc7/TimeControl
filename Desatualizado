.tl-lbl{font-size:13px;color:var(--gray-800);flex:1}
.tl-m{font-size:11px;color:var(--gray-400)}
.al-item{display:flex;align-items:flex-start;gap:11px;padding:11px 13px;border-radius:var(--r);border-left:3px solid;margin-bottom:7px}
