function doClk(state){
  clockState=state;
  if(state==='in'){clockStart=Date.now();startClock()}
  else clearInterval(clockTick);
  const msgs={in:'Entrada registrada!',break:'Intervalo iniciado!',out:'Saída registrada!'};
  toast(msgs[state],'ok');
  // Registro real do funcionário logado
  const tipo=state==='in'?'Entrada':state==='break'?'Intervalo':'Saída';
  const entry={
    id:'r_'+Date.now(),
    userId:currentUser?.id||'',
    nome:currentUser?.nome||ROLES[role].name,
    tipo:tipo,
    local:'Escritório SP',
    hora:nowStr(),
    data:new Date().toLocaleDateString('pt-BR'),
    ts:Date.now()
  };
  DB.registros.unshift(entry);
  saveRegistro(entry);  // persiste no localStorage
  // Atualiza stats reais
  if(tipo==='Entrada')  { DB.stats.presentes++; DB.stats.ausentes=Math.max(0,DB.stats.ausentes-1); }
  if(tipo==='Saída')    { DB.stats.presentes=Math.max(0,DB.stats.presentes-1); }
  if(tipo==='Intervalo'){ DB.stats.intervalo++; }
  if(tipo==='Retorno')  { DB.stats.intervalo=Math.max(0,DB.stats.intervalo-1); }
  // Injeta no feed do monitor se estiver aberto
  injectFeedEntry(entry);
  updateMonitorStats();
  goPage('dashboard');
}

