}
function saveEmpresa(emp){
  const list=getEmpresas();
  const idx=list.findIndex(e=>e.id===emp.id);
  if(idx>=0) list[idx]=emp; else list.push(emp);
  try{ localStorage.setItem('tc_empresas', JSON.stringify(list)); }catch(e){}
}
function gerarCodigo(){
  // Gera código tipo TC-XXXX-YYYY
  const chars='ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
  const part=n=>Array.from({length:n},()=>chars[Math.floor(Math.random()*chars.length)]).join('');
  return 'TC-'+part(4)+'-'+part(4);
}

function validarCodigoAoDigitar(inp){
  const cod = inp.value.trim().toUpperCase();
  inp.value = cod;
  if(cod.length < 11){ clearM('co-m'); inp.classList.remove('ok','err'); return; }
  const emp = buscarEmpresaPorCodigo(cod);
  if(emp){
    setM('co-m','✓ Empresa encontrada: '+emp.nome,'ok');
    inp.classList.add('ok'); inp.classList.remove('err');
  } else {
    setM('co-m','❌ Código não encontrado.','err');
    inp.classList.add('err'); inp.classList.remove('ok');
  }
}

function buscarEmpresaPorCodigo(codigo){
  return getEmpresas().find(e=>e.codigo===codigo.toUpperCase().trim());
}

// Hash simples (não use em produção — use bcrypt no backend)
function hashSimple(str){
  let h=0;
  for(let i=0;i<str.length;i++){ h=((h<<5)-h)+str.charCodeAt(i); h|=0; }
  return 'h'+Math.abs(h).toString(36);
}

/* ════ AUTH ════ */
let regStep=1;
function authTab(t){
  ['login','reg'].forEach(x=>{document.getElementById('sec-'+x).classList.toggle('active',x===t);document.getElementById('at-'+x).classList.toggle('active',x===t)});
  if(t==='login') hideForgot();
}
function showForgot(){document.getElementById('login-main').classList.add('hide');document.getElementById('forgot-p').classList.add('show')}
function hideForgot(){document.getElementById('login-main').classList.remove('hide');document.getElementById('forgot-p').classList.remove('show')}
function doForgot(){const e=document.getElementById('forg-e').value.trim();if(!e||!e.includes('@')){toast('Informe um e-mail válido','err');return}toast('Link enviado para '+e,'ok');setTimeout(hideForgot,1500)}
function eyeT(id,btn){const i=document.getElementById(id);const s=i.type==='password';i.type=s?'text':'password';btn.textContent=s?'🙈':'👁'}
document.querySelectorAll('input[name="rg-role"]').forEach(r=>{r.addEventListener('change',function(){const v=this.value;document.getElementById('eg').style.display=v==='admin'?'block':'none';document.getElementById('cg').style.display=v!=='admin'?'block':'none'})});
function goStep(n){
  if(n>regStep&&!valStep(regStep))return;
  document.getElementById('sp'+regStep).classList.remove('active');document.getElementById('si'+regStep).classList.remove('active');
  if(n>regStep)document.getElementById('si'+regStep).classList.add('done');else document.getElementById('si'+regStep).classList.remove('done');
  regStep=n;document.getElementById('sp'+n).classList.add('active');document.getElementById('si'+n).classList.add('active');
}
function valStep(s){
  if(s===1){
    // Valida perfil selecionado
    const r=document.querySelector('input[name="rg-role"]:checked');
    if(!r){ setM('rr-m','Selecione um perfil para continuar.','err'); return false; }
    clearM('rr-m');

    if(r.value==='admin'){
      // Admin: valida nome da empresa
      const emp=document.getElementById('rg-emp').value.trim();
      if(!emp){ setM('em-m','Informe o nome da empresa.','err'); return false; }
      clearM('em-m');

    } else {
      // Outros perfis: valida código REAL contra banco
      const cod=document.getElementById('rg-cod').value.trim().toUpperCase();
      if(!cod){ setM('co-m','Informe o código da empresa.','err'); return false; }

      const empresaEncontrada = buscarEmpresaPorCodigo(cod);
      if(!empresaEncontrada){
        setM('co-m','❌ Código inválido — verifique com seu administrador.','err');
        return false;
      }
      // Código válido — mostra feedback positivo
      setM('co-m','✓ Empresa encontrada: '+empresaEncontrada.nome,'ok');
    }
    return true;
  }

  if(s===2){
    if(!document.getElementById('rg-nome').value.trim()){ setM('no-m','Informe seu nome.','err'); return false; }
    clearM('no-m');
    if(document.getElementById('rg-cpf').value.length<14){ setM('cp-m','CPF inválido.','err'); return false; }
    clearM('cp-m');
    return true;
  }
  return true;
}
function chkE(i){const v=i.value.trim();if(!v){clearM('re-m');return}const ok=v.includes('@')&&v.includes('.');setM('re-m',ok?'E-mail válido ✓':'E-mail inválido',ok?'ok':'err')}
function chkS(i){const v=i.value;document.getElementById('str-w').classList.toggle('show',v.length>0);let sc=0;if(v.length>=8)sc++;if(/[A-Z]/.test(v))sc++;if(/[0-9]/.test(v))sc++;if(/[^A-Za-z0-9]/.test(v))sc++;const p=[0,25,50,75,100][sc];const c=['','#C0392B','#E67E22','#2980B9','#1E7A4A'][sc];const l=['','Muito fraca','Fraca','Boa','Forte'][sc];document.getElementById('str-f').style.cssText=`width:${p}%;background:${c||'#ccc'}`;document.getElementById('str-l').textContent=l||'';if(document.getElementById('rg-pass2').value)chkM()}
function chkM(){const p1=document.getElementById('rg-pass').value,p2=document.getElementById('rg-pass2').value;if(!p2){clearM('rp2-m');return}p1===p2?setM('rp2-m','Senhas coincidem ✓','ok'):setM('rp2-m','As senhas não coincidem','err')}
function mCPF(i){let v=i.value.replace(/\D/g,'').slice(0,11);if(v.length>9)v=v.replace(/(\d{3})(\d{3})(\d{3})(\d{0,2})/,'$1.$2.$3-$4');else if(v.length>6)v=v.replace(/(\d{3})(\d{3})(\d{0,3})/,'$1.$2.$3');else if(v.length>3)v=v.replace(/(\d{3})(\d{0,3})/,'$1.$2');i.value=v}
function mPhone(i){let v=i.value.replace(/\D/g,'').slice(0,11);if(v.length>10)v=v.replace(/(\d{2})(\d{5})(\d{4})/,'($1) $2-$3');else if(v.length>6)v=v.replace(/(\d{2})(\d{4,5})(\d{0,4})/,'($1) $2-$3');else if(v.length>2)v=v.replace(/(\d{2})(\d{0,5})/,'($1) $2');i.value=v}
function doLogin(){
  const e=document.getElementById('li-email').value.trim().toLowerCase();
  const p=document.getElementById('li-pass').value;
  let ok=true;
  if(!e||!e.includes('@')){setM('li-em','E-mail inválido.','err');ok=false}else clearM('li-em');
  if(p.length<6){setM('li-pm','Senha muito curta.','err');ok=false}else clearM('li-pm');
  if(!ok)return;

  const btn=document.getElementById('btn-login');
  btn.textContent='VERIFICANDO...';btn.classList.add('loading');

  setTimeout(()=>{
    btn.textContent='ENTRAR NO SISTEMA';btn.classList.remove('loading');

    // Busca usuário no banco local
    const users=getUsers();
    const user=users.find(u=>u.email===e);

    if(!user){
      setM('li-em','E-mail não cadastrado.','err');
      toast('Conta não encontrada. Crie uma conta primeiro.','err');
      return;
    }
    if(user.senha!==hashSimple(p)){
      setM('li-pm','Senha incorreta.','err');
      toast('Senha incorreta. Tente novamente.','err');
      return;
    }

    clearM('li-em');clearM('li-pm');

    if(document.getElementById('remember').checked){
      try{
        localStorage.setItem('tc_session', JSON.stringify({email:user.email,role:user.role,nome:user.nome,id:user.id}));
      }catch(ex){}
    }
    toast('Login realizado com sucesso!','ok');
    launchApp(user.role, user);
  },800);
}
function doReg(){
  const e=document.getElementById('rg-email').value.trim().toLowerCase();
  const p=document.getElementById('rg-pass').value;
  const p2=document.getElementById('rg-pass2').value;
  const t=document.getElementById('terms').checked;
  const nome=document.getElementById('rg-nome').value.trim();
  const sobr=document.getElementById('rg-sobr').value.trim();
  const role_sel=document.querySelector('input[name="rg-role"]:checked')?.value;
  let ok=true;

  if(!e||!e.includes('@')){setM('re-m','E-mail inválido.','err');ok=false}else clearM('re-m');
  if(p.length<8){setM('rp-m','Mínimo 8 caracteres.','err');ok=false}else clearM('rp-m');
  if(p!==p2){setM('rp2-m','Senhas não coincidem.','err');ok=false}else clearM('rp2-m');
  if(!t){setM('te-m','Aceite os termos para continuar.','err');ok=false}else clearM('te-m');
  if(!ok)return;

  // Verifica se e-mail já existe
  const users=getUsers();
  if(users.find(u=>u.email===e)){
    setM('re-m','Este e-mail já está cadastrado.','err');
    toast('E-mail já cadastrado. Faça login.','err');
    return;
  }

  const btn=document.getElementById('btn-reg');btn.textContent='CRIANDO...';btn.classList.add('loading');

  setTimeout(()=>{
    btn.classList.remove('loading');

    // Salva usuário
    const isAdmin = role_sel === 'admin';
    let empresaId = '', empresaCodigo = '', empresaNome = '';

    if(isAdmin){
      // Cria empresa e gera código único
      empresaNome = document.getElementById('rg-emp')?.value.trim()||'';
      empresaCodigo = gerarCodigo();
      const novaEmpresa = {
        id: 'emp_'+Date.now(),
        nome: empresaNome,
        codigo: empresaCodigo,
        adminEmail: e,
        createdAt: new Date().toISOString(),
      };
      saveEmpresa(novaEmpresa);
      empresaId = novaEmpresa.id;
    } else {
      // Valida código da empresa informado
      const codigoInformado = document.getElementById('rg-cod')?.value.trim()||'';
      const empEncontrada = buscarEmpresaPorCodigo(codigoInformado);
      if(!empEncontrada){
        btn.classList.remove('loading');
        setM('co-m','Código de empresa inválido ou não encontrado.','err');
        toast('Código da empresa não encontrado. Verifique com seu administrador.','err');
        return;
      }
      empresaId = empEncontrada.id;
      empresaNome = empEncontrada.nome;
      empresaCodigo = empEncontrada.codigo;
    }

    const newUser={
      id:'u_'+Date.now(),
      nome: (nome+' '+sobr).trim(),
      email: e,
      senha: hashSimple(p),
      role: role_sel||'func',
      cargo: document.getElementById('rg-cargo')?.value.trim()||'',
      cpf: document.getElementById('rg-cpf')?.value.trim()||'',
      tel: document.getElementById('rg-tel')?.value.trim()||'',
      empresaId: empresaId,
      empresaNome: empresaNome,
      empresaCodigo: empresaCodigo,
      createdAt: new Date().toISOString(),
    };
    saveUser(newUser);

    // Mostra o código para o Admin copiar
    const msg = isAdmin
      ? `<div style="background:var(--navy-pale);border:1.5px solid #C5D9EE;border-radius:10px;padding:1rem;margin-bottom:1rem">
           <div style="font-size:12px;color:var(--gray-600);margin-bottom:6px;font-weight:600;text-transform:uppercase;letter-spacing:.06em">Código da sua empresa</div>
           <div style="font-family:var(--cond);font-size:28px;font-weight:800;color:var(--navy);letter-spacing:.12em">${empresaCodigo}</div>
           <div style="font-size:12px;color:var(--gray-400);margin-top:6px">Compartilhe este código com seus funcionários para que eles possam criar conta e entrar no sistema.</div>
           <button onclick="navigator.clipboard.writeText('${empresaCodigo}').then(()=>this.textContent='✓ Copiado!').catch(()=>{})" style="margin-top:10px;padding:7px 14px;background:var(--navy);color:#fff;border:none;border-radius:8px;font-size:12px;font-weight:600;cursor:pointer;font-family:var(--font)">📋 Copiar código</button>
         </div>`
      : `<div style="background:var(--green-bg);border:1px solid #A7D7BC;border-radius:10px;padding:1rem;margin-bottom:1rem;font-size:13px;color:var(--green)">✅ Vinculado à empresa <strong>${empresaNome}</strong></div>`;

    document.getElementById('reg-form').style.display='none';
    document.getElementById('reg-ok').classList.add('show');
    document.getElementById('reg-ok').innerHTML = `
      <div class="suc-icon">✓</div>
      <div class="suc-title">${isAdmin?'Empresa criada!':'Conta criada!'}</div>
      <div class="suc-sub">${isAdmin?'Sua empresa foi registrada com sucesso.':'Seu cadastro foi realizado com sucesso.'}</div>
      ${msg}
      <button class="btn-auth" onclick="authTab('login')">IR PARA O LOGIN</button>
    `;
    toast('Conta criada com sucesso!','ok');
  },1000);
}
function setM(id,txt,cls){const el=document.getElementById(id);if(!el)return;el.textContent=txt;el.className='f-msg '+cls}
function clearM(id){const el=document.getElementById(id);if(!el)return;el.textContent='';el.className='f-msg'}

/* ════ APP INIT ════ */
function launchApp(r, user){
  role=r;
  currentUser=user||{nome:ROLES[r].name,email:'',role:r,id:'guest'};
  const R=ROLES[r];
  const displayName=currentUser.nome&&currentUser.nome.trim()!==''?currentUser.nome:R.name;
  const initials=displayName.split(' ').filter(Boolean).slice(0,2).map(n=>n[0].toUpperCase()).join('');
  document.getElementById('auth').classList.add('gone');
  document.getElementById('app').classList.add('visible');
  document.getElementById('sb-av').textContent=initials||R.init;
  document.getElementById('sb-name').textContent=displayName;
  document.getElementById('sb-role').textContent=R.label+(user?.empresaNome?' · '+user.empresaNome:'');
  document.getElementById('tb-av').textContent=initials||R.init;
  buildNav(r);goPage('dashboard');
}
function doLogout(){
  try{localStorage.removeItem('tc_session')}catch(ex){}
  clearInterval(clockTick);
  clockState='out'; currentUser=null;
  document.getElementById('auth').classList.remove('gone');
  document.getElementById('app').classList.remove('visible');
  document.getElementById('content').innerHTML='';
  authTab('login');
  toast('Sessão encerrada.','ok');
}
try{
  const sess=localStorage.getItem('tc_session');
  if(sess){
    const user=JSON.parse(sess);
    window.addEventListener('DOMContentLoaded',()=>launchApp(user.role, user));
  }
}catch(ex){}

