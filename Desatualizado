  const empty=feed.querySelector('.empty');
  if(empty) empty.remove();
  const clsMap={'Entrada':'bg','Saída':'br','Intervalo':'ba','Retorno':'bb'};
  const icMap={'Entrada':'🟢','Saída':'🔴','Intervalo':'🟡','Retorno':'🔵'};
  const init=entry.nome.split(' ').slice(0,2).map(n=>n[0]).join('').toUpperCase();
  const row=document.createElement('div');
  row.className='feed-row feed-new';
  row.innerHTML=`
    <div class="feed-time">${entry.hora}</div>
    <div class="feed-av" style="background:var(--navy-pale);color:var(--navy);width:30px;height:30px;font-size:11px;font-weight:700;border-radius:50%;display:flex;align-items:center;justify-content:center">${init}</div>
