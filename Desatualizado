<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Time Control</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700;800&family=Barlow+Condensed:wght@600;700;800&family=Barlow+Semi+Condensed:wght@400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --navy:#1B3A5C;--navy-mid:#2A4F78;--navy-light:#3A6899;
  --navy-pale:#EAF0F8;--navy-ultra:#F0F4F9;
  --white:#FFFFFF;--gray-50:#F7F8FA;--gray-100:#ECEEF2;
  --gray-200:#D4D8E0;--gray-400:#8A93A6;--gray-600:#525D72;--gray-800:#2C3444;
  --green:#1E7A4A;--green-bg:#E8F5EE;
  --amber:#92580A;--amber-bg:#FEF3DC;
  --red:#B91C1C;--red-bg:#FEE2E2;
  --blue:#2563EB;--blue-bg:#EFF6FF;
  --purple:#6B21A8;--purple-bg:#F3E8FF;
  --font:'Barlow',sans-serif;--cond:'Barlow Condensed',sans-serif;--semi:'Barlow Semi Condensed',sans-serif;
  --sidebar-w:242px;--topbar-h:58px;--r:10px;--rl:14px;
  --shadow:0 1px 3px rgba(27,58,92,.07),0 4px 12px rgba(27,58,92,.05);
}
html,body{height:100%;font-family:var(--font);background:var(--gray-50);color:var(--gray-800);font-size:14px;line-height:1.5;overflow-x:hidden}
button,input,select,textarea{font-family:var(--font)}
::-webkit-scrollbar{width:5px;height:5px}
::-webkit-scrollbar-thumb{background:var(--gray-200);border-radius:10px}

/* ── AUTH ── */
.auth-screen{position:fixed;inset:0;z-index:900;display:grid;grid-template-columns:1fr 1fr;transition:opacity .4s,visibility .4s}
.auth-screen.gone{opacity:0;visibility:hidden;pointer-events:none}
@media(max-width:700px){.auth-screen{grid-template-columns:1fr}}
.auth-left{background:var(--navy);display:flex;flex-direction:column;justify-content:space-between;padding:2.5rem;position:relative;overflow:hidden}
.auth-left::before{content:'';position:absolute;width:500px;height:500px;border-radius:50%;border:70px solid rgba(255,255,255,.04);top:-150px;left:-150px}
.auth-left::after{content:'';position:absolute;width:360px;height:360px;border-radius:50%;border:45px solid rgba(255,255,255,.05);bottom:-80px;right:-80px}
@media(max-width:700px){.auth-left{display:none}}
.al-brand{display:flex;align-items:center;gap:12px;position:relative;z-index:1}
.al-brand-icon{width:46px;height:46px;border-radius:12px;background:rgba(255,255,255,.13);display:flex;align-items:center;justify-content:center}
.al-brand-name{font-family:var(--cond);font-size:22px;font-weight:800;color:#fff;letter-spacing:.04em}
.al-brand-name small{display:block;font-size:10px;font-weight:500;letter-spacing:.15em;color:rgba(255,255,255,.45);text-transform:uppercase;margin-top:2px}
.al-hero{position:relative;z-index:1}
.al-headline{font-family:var(--cond);font-size:46px;font-weight:800;color:#fff;line-height:1.05;margin-bottom:1rem}
.al-headline em{font-style:normal;color:rgba(255,255,255,.38)}
.al-desc{font-size:14px;color:rgba(255,255,255,.6);line-height:1.7;max-width:320px;margin-bottom:1.75rem}
.al-pills{display:flex;flex-direction:column;gap:9px}
.al-pill{display:flex;align-items:center;gap:10px;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);border-radius:8px;padding:9px 13px;color:rgba(255,255,255,.78);font-size:13px;font-weight:500}
.al-pill-ic{width:26px;height:26px;border-radius:6px;background:rgba(255,255,255,.12);display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0}
.al-foot{position:relative;z-index:1;font-size:11px;color:rgba(255,255,255,.3)}
.auth-right{background:var(--white);display:flex;align-items:center;justify-content:center;padding:2.5rem 2rem;overflow-y:auto}
.auth-box{width:100%;max-width:420px;animation:slideUp .4s ease both}
@keyframes slideUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
.auth-tabs{display:flex;background:var(--gray-100);border-radius:var(--r);padding:4px;margin-bottom:1.75rem}
.at-btn{flex:1;padding:9px;border-radius:8px;font-size:13px;font-weight:700;color:var(--gray-400);background:transparent;border:none;cursor:pointer;transition:all .2s;letter-spacing:.01em}
.at-btn.active{background:var(--white);color:var(--navy);box-shadow:0 1px 4px rgba(27,58,92,.12)}
.auth-title{font-family:var(--cond);font-size:28px;font-weight:800;color:var(--navy);margin-bottom:4px}
.auth-sub{font-size:13px;color:var(--gray-400);margin-bottom:1.5rem}
.f-sec{display:none}.f-sec.active{display:block}
.f-group{margin-bottom:.9rem}
.f-row2{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.f-label{display:flex;justify-content:space-between;align-items:center;font-size:11px;font-weight:700;color:var(--gray-600);text-transform:uppercase;letter-spacing:.07em;margin-bottom:5px}
.f-wrap{position:relative}
.f-ic{position:absolute;left:11px;top:50%;transform:translateY(-50%);color:var(--gray-400);font-size:15px;pointer-events:none}
.f-in,.f-sel{width:100%;padding:10px 11px 10px 36px;border:1.5px solid var(--gray-200);border-radius:var(--r);font-family:var(--font);font-size:14px;color:var(--gray-800);background:var(--gray-50);outline:none;transition:border-color .2s,box-shadow .2s,background .2s;appearance:none}
.f-in:focus,.f-sel:focus{border-color:var(--navy-mid);background:var(--white);box-shadow:0 0 0 3px rgba(27,58,92,.08)}
.f-in.err{border-color:var(--red)}.f-in.ok{border-color:var(--green)}
.f-eye{position:absolute;right:11px;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--gray-400);cursor:pointer;font-size:15px;line-height:1}
.f-msg{font-size:11px;margin-top:3px;height:14px}
.f-msg.err{color:var(--red)}.f-msg.ok{color:var(--green)}
.prof-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:.9rem}
.prof-radio{display:none}
.prof-lbl{display:flex;flex-direction:column;align-items:center;gap:5px;padding:11px 8px;border:2px solid var(--gray-200);border-radius:var(--r);font-size:12px;font-weight:700;color:var(--gray-600);background:var(--gray-50);cursor:pointer;transition:all .18s;text-align:center}
.prof-lbl .pic{font-size:22px}
.prof-radio:checked+.prof-lbl{border-color:var(--navy);background:var(--navy-pale);color:var(--navy);box-shadow:0 0 0 3px rgba(27,58,92,.08)}
.steps{display:flex;align-items:center;margin-bottom:1.4rem}
.step-it{display:flex;flex-direction:column;align-items:center;flex:1;position:relative}
.step-it:not(:last-child)::after{content:'';position:absolute;top:13px;left:50%;width:100%;height:2px;background:var(--gray-200);z-index:0;transition:background .3s}
.step-it.done:not(:last-child)::after{background:var(--navy)}
.step-circ{width:26px;height:26px;border-radius:50%;border:2px solid var(--gray-200);background:var(--white);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:var(--gray-400);position:relative;z-index:1;transition:all .25s}
.step-it.active .step-circ,.step-it.done .step-circ{border-color:var(--navy);background:var(--navy);color:#fff}
.step-lbl{font-size:9px;font-weight:700;color:var(--gray-400);margin-top:3px;text-transform:uppercase;letter-spacing:.07em}
.step-it.active .step-lbl,.step-it.done .step-lbl{color:var(--navy)}
.step-panel{display:none}.step-panel.active{display:block;animation:slideUp .22s ease both}
.str-wrap{display:none;margin-top:5px}.str-wrap.show{display:block}
.str-bar{height:4px;background:var(--gray-200);border-radius:2px;overflow:hidden}
.str-fill{height:100%;border-radius:2px;transition:width .3s,background .3s}
.str-lbl{font-size:11px;color:var(--gray-400);margin-top:2px}
.chk-row{display:flex;align-items:flex-start;gap:8px;margin:.5rem 0}
.chk-row input[type=checkbox]{width:15px;height:15px;flex-shrink:0;margin-top:2px;accent-color:var(--navy);cursor:pointer}
.chk-row label{font-size:12px;color:var(--gray-600);cursor:pointer;line-height:1.5}
.chk-row a{color:var(--navy);font-weight:600;text-decoration:none}
.btn-auth{width:100%;padding:13px;background:var(--navy);color:#fff;border:none;border-radius:var(--r);font-family:var(--cond);font-size:16px;font-weight:800;letter-spacing:.06em;text-transform:uppercase;cursor:pointer;box-shadow:0 4px 12px rgba(27,58,92,.22);transition:all .2s}
.btn-auth:hover{background:var(--navy-mid);transform:translateY(-1px)}
.btn-auth.loading{opacity:.7;pointer-events:none}
.btn-ghost{background:none;border:none;font-size:12px;color:var(--navy-light);cursor:pointer;font-weight:600;padding:0}
.btn-ghost:hover{text-decoration:underline}
.btn-nav-row{display:flex;gap:8px;margin-top:1.1rem}
.btn-back{flex:1;padding:11px;background:transparent;border:1.5px solid var(--gray-200);border-radius:var(--r);font-family:var(--cond);font-size:14px;font-weight:700;color:var(--gray-600);cursor:pointer;text-transform:uppercase;letter-spacing:.04em;transition:all .2s}
.btn-back:hover{border-color:var(--navy);color:var(--navy)}
.btn-next{flex:2}
.divider{display:flex;align-items:center;gap:10px;margin:1.1rem 0;font-size:12px;color:var(--gray-400)}
.divider::before,.divider::after{content:'';flex:1;height:1px;background:var(--gray-200)}
.forgot-panel{display:none}.forgot-panel.show{display:block;animation:slideUp .2s ease both}
.login-main.hide{display:none}
.success-sc{display:none;text-align:center;padding:1rem 0}.success-sc.show{display:block;animation:slideUp .3s ease both}
.suc-icon{width:60px;height:60px;border-radius:50%;background:var(--green-bg);color:var(--green);font-size:28px;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem}
.suc-title{font-family:var(--cond);font-size:24px;font-weight:800;color:var(--navy);margin-bottom:6px}
.suc-sub{font-size:13px;color:var(--gray-400);line-height:1.6;margin-bottom:1.5rem}

/* ── APP ── */
.app{display:flex;height:100vh;overflow:hidden;opacity:0;transition:opacity .35s}
.app.visible{opacity:1}
.sidebar{width:var(--sidebar-w);background:var(--navy);display:flex;flex-direction:column;flex-shrink:0;overflow-y:auto;overflow-x:hidden;transition:width .28s,transform .28s;position:relative;z-index:50}
.sidebar.collapsed{width:62px}
@media(max-width:860px){.sidebar{position:fixed;top:0;bottom:0;left:0;transform:translateX(-100%);z-index:200;width:var(--sidebar-w)}.sidebar.mob-open{transform:translateX(0)}}
.sb-mob-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:199}.sb-mob-bg.show{display:block}
.sb-top{padding:1.1rem .9rem .9rem;border-bottom:1px solid rgba(255,255,255,.08);flex-shrink:0}
.sb-brand{display:flex;align-items:center;gap:9px;margin-bottom:1rem}
.sb-brand-ic{width:34px;height:34px;border-radius:9px;background:rgba(255,255,255,.13);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.sb-brand-nm{font-family:var(--cond);font-size:16px;font-weight:800;color:#fff;letter-spacing:.05em;white-space:nowrap;overflow:hidden;transition:opacity .2s}
.sidebar.collapsed .sb-brand-nm{opacity:0;width:0}
.sb-user{display:flex;align-items:center;gap:9px;background:rgba(255,255,255,.07);border-radius:var(--r);padding:9px 11px}
.sb-av{width:34px;height:34px;border-radius:50%;background:rgba(255,255,255,.18);display:flex;align-items:center;justify-content:center;font-family:var(--cond);font-size:13px;font-weight:700;color:#fff;flex-shrink:0}
.sb-info{overflow:hidden;transition:opacity .2s,width .2s}
.sidebar.collapsed .sb-info{opacity:0;width:0}
.sb-name{font-size:13px;font-weight:600;color:#fff;white-space:nowrap}
.sb-role{font-size:10px;color:rgba(255,255,255,.45);text-transform:uppercase;letter-spacing:.08em}
.sb-toggle{position:absolute;top:50%;right:-13px;transform:translateY(-50%);width:26px;height:26px;border-radius:50%;background:var(--white);border:2px solid var(--gray-200);color:var(--navy);font-size:12px;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:var(--shadow);z-index:10}
@media(max-width:860px){.sb-toggle{display:none}}
.sb-nav{padding:.9rem .7rem;flex:1}
.sb-sec{font-size:9px;font-weight:700;color:rgba(255,255,255,.3);text-transform:uppercase;letter-spacing:.12em;padding:.65rem .5rem .25rem;white-space:nowrap;overflow:hidden;transition:opacity .2s}
.sidebar.collapsed .sb-sec{opacity:0}
.sb-item{display:flex;align-items:center;gap:9px;padding:8px 10px;border-radius:8px;font-size:13px;font-weight:500;color:rgba(255,255,255,.62);background:transparent;border:none;cursor:pointer;transition:all .13s;width:100%;text-align:left;font-family:var(--font);white-space:nowrap;overflow:hidden;position:relative}
.sb-item:hover{background:rgba(255,255,255,.08);color:#fff}
.sb-item.active{background:rgba(255,255,255,.14);color:#fff;font-weight:600}
.sb-ic{font-size:17px;flex-shrink:0;width:20px;text-align:center}
.sb-lbl{overflow:hidden;transition:opacity .2s,max-width .2s;max-width:160px}
.sidebar.collapsed .sb-lbl{opacity:0;max-width:0}
.sb-badge{margin-left:auto;font-size:10px;font-weight:700;background:#E24B4A;color:#fff;border-radius:10px;padding:1px 6px;flex-shrink:0;transition:opacity .2s}
.sidebar.collapsed .sb-badge{opacity:0}
.sb-foot{padding:.7rem;border-top:1px solid rgba(255,255,255,.08);flex-shrink:0}
.btn-logout{display:flex;align-items:center;gap:8px;width:100%;padding:8px 10px;border-radius:8px;font-size:13px;font-weight:500;color:rgba(255,255,255,.45);background:transparent;border:none;cursor:pointer;transition:all .15s;font-family:var(--font);white-space:nowrap;overflow:hidden}
.btn-logout:hover{background:rgba(255,255,255,.07);color:#F4A0A0}
.sidebar.collapsed .btn-logout span{display:none}
.main-area{flex:1;display:flex;flex-direction:column;overflow:hidden;min-width:0}
.topbar{height:var(--topbar-h);background:var(--white);border-bottom:1px solid var(--gray-100);display:flex;align-items:center;justify-content:space-between;padding:0 1.5rem;flex-shrink:0;gap:.75rem}
.tb-left{display:flex;align-items:center;gap:.75rem;min-width:0}
.tb-mob-menu{display:none;background:none;border:none;font-size:22px;color:var(--navy);cursor:pointer;flex-shrink:0}
@media(max-width:860px){.tb-mob-menu{display:flex}}
.tb-title{font-family:var(--cond);font-size:19px;font-weight:800;color:var(--navy);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.tb-sub{font-size:11px;color:var(--gray-400);white-space:nowrap}
.tb-right{display:flex;align-items:center;gap:7px;flex-shrink:0}
.tb-btn{width:34px;height:34px;border-radius:9px;border:1px solid var(--gray-200);background:transparent;display:flex;align-items:center;justify-content:center;color:var(--gray-600);cursor:pointer;font-size:16px;position:relative;transition:background .15s}
.tb-btn:hover{background:var(--gray-100)}
.notif-dot{width:7px;height:7px;background:#E24B4A;border-radius:50%;border:2px solid #fff;position:absolute;top:5px;right:5px}
.tb-av{width:34px;height:34px;border-radius:50%;background:var(--navy-pale);color:var(--navy);font-family:var(--cond);font-size:13px;font-weight:700;display:flex;align-items:center;justify-content:center;border:2px solid var(--navy-pale);cursor:pointer}
.content{flex:1;overflow-y:auto;padding:1.5rem}
@media(max-width:600px){.content{padding:1rem}}
.page{display:none}.page.active{display:block;animation:slideUp .22s ease both}

/* ── COMPONENTS ── */
.ph{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:1.25rem;flex-wrap:wrap;gap:.75rem}
.ph-title{font-family:var(--cond);font-size:24px;font-weight:800;color:var(--navy)}
.ph-sub{font-size:12px;color:var(--gray-400);margin-top:1px}
.btn{display:inline-flex;align-items:center;gap:6px;padding:8px 15px;border-radius:var(--r);font-size:13px;font-weight:600;font-family:var(--font);cursor:pointer;border:none;transition:all .17s;white-space:nowrap}
.btn-primary{background:var(--navy);color:#fff}.btn-primary:hover{background:var(--navy-mid)}
.btn-secondary{background:var(--white);color:var(--gray-800);border:1px solid var(--gray-200)}.btn-secondary:hover{background:var(--gray-50)}
.btn-success{background:var(--green-bg);color:var(--green);border:1px solid #A7D7BC}
.btn-danger{background:var(--red-bg);color:var(--red);border:1px solid #FECACA}
.btn-sm{padding:6px 11px;font-size:12px}.btn-xs{padding:4px 9px;font-size:11px}
.grid{display:grid;gap:.9rem;margin-bottom:1.1rem}
.g2{grid-template-columns:repeat(2,1fr)}.g3{grid-template-columns:repeat(3,1fr)}.g4{grid-template-columns:repeat(4,1fr)}
@media(max-width:900px){.g4{grid-template-columns:repeat(2,1fr)}.g3{grid-template-columns:repeat(2,1fr)}}
@media(max-width:500px){.g4,.g3,.g2{grid-template-columns:1fr}}
.metric{background:var(--white);border:1px solid var(--gray-100);border-radius:var(--rl);padding:1.1rem 1.2rem;box-shadow:var(--shadow)}
.m-label{font-size:11px;font-weight:700;color:var(--gray-400);text-transform:uppercase;letter-spacing:.07em;display:flex;align-items:center;gap:5px;margin-bottom:7px}
.m-val{font-family:var(--cond);font-size:30px;font-weight:800;color:var(--navy);line-height:1;margin-bottom:5px}
.m-val sub{font-size:14px;font-weight:600}
.m-chg{font-size:12px;display:flex;align-items:center;gap:3px}
.cup{color:var(--green)}.cdn{color:var(--red)}.cne{color:var(--gray-400)}
.card{background:var(--white);border:1px solid var(--gray-100);border-radius:var(--rl);padding:1.1rem 1.2rem;box-shadow:var(--shadow);margin-bottom:.9rem}
.card:last-child{margin-bottom:0}
.ch{display:flex;align-items:center;justify-content:space-between;margin-bottom:.9rem;flex-wrap:wrap;gap:.5rem}
.ct{font-family:var(--semi);font-size:14px;font-weight:600;color:var(--navy)}
.cl{font-size:12px;color:var(--navy-light);background:none;border:none;cursor:pointer;font-family:var(--font);font-weight:600}
.cl:hover{text-decoration:underline}
.tc{display:grid;grid-template-columns:1fr 1fr;gap:.9rem}
@media(max-width:800px){.tc{grid-template-columns:1fr}}
.tw{overflow-x:auto;border-radius:var(--r)}
table{width:100%;border-collapse:collapse;font-size:13px}
th{text-align:left;padding:8px 11px;font-size:10px;font-weight:700;color:var(--gray-400);text-transform:uppercase;letter-spacing:.07em;border-bottom:1px solid var(--gray-100);white-space:nowrap}
td{padding:9px 11px;border-bottom:1px solid var(--gray-100);color:var(--gray-800);vertical-align:middle}
tr:last-child td{border-bottom:none}
tr:hover td{background:var(--gray-50)}
.mono{font-family:var(--semi)}
.badge{display:inline-flex;align-items:center;gap:4px;font-size:11px;font-weight:600;padding:3px 8px;border-radius:20px;white-space:nowrap}
.badge::before{content:'';width:5px;height:5px;border-radius:50%;background:currentColor;flex-shrink:0}
.bg{background:var(--green-bg);color:var(--green)}.br{background:var(--red-bg);color:var(--red)}
.ba{background:var(--amber-bg);color:var(--amber)}.bb{background:var(--blue-bg);color:var(--blue)}
.bp{background:var(--purple-bg);color:var(--purple)}.bn{background:var(--navy-pale);color:var(--navy)}
.bx{background:var(--gray-100);color:var(--gray-600)}
.rtag{display:inline-flex;align-items:center;font-size:10px;font-weight:700;padding:2px 8px;border-radius:5px;text-transform:uppercase;letter-spacing:.06em}
.r-admin{background:var(--navy-pale);color:var(--navy)}.r-rh{background:var(--purple-bg);color:var(--purple)}
.r-gestor{background:var(--amber-bg);color:var(--amber)}.r-func{background:var(--green-bg);color:var(--green)}
.prog{height:7px;background:var(--gray-100);border-radius:4px;overflow:hidden}
.pf{height:100%;border-radius:4px;transition:width .6s ease}
.bchart{display:flex;align-items:flex-end;gap:7px}
.bcc{flex:1;display:flex;flex-direction:column;align-items:center;gap:4px}
.bfill{width:100%;border-radius:4px 4px 0 0;min-height:3px}
.blbl{font-size:10px;color:var(--gray-400)}
.av{width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:var(--cond);font-size:11px;font-weight:700;flex-shrink:0}
.av-row{display:flex;align-items:center;gap:9px}
.tl{display:flex;flex-direction:column}
.tl-row{display:flex;align-items:center;gap:11px;padding:8px 0;border-bottom:1px solid var(--gray-100)}
.tl-row:last-child{border-bottom:none}
.tl-t{font-family:var(--semi);font-size:12px;color:var(--gray-400);min-width:36px}
